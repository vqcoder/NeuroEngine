{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "watchlab",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "cwd": "apps/watchlab"
    },
    {
      "name": "dashboard",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 4173,
      "cwd": "apps/dashboard"
    },
    {
      "name": "alpha-engine",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3100,
      "cwd": "apps/alpha-engine"
    },
    {
      "name": "biograph-api",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "port": 8000,
      "cwd": "services/biograph_api"
    }
  ]
}
