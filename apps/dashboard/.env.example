# Required: API base URL for your biograph-api deployment
VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional: Bearer token for local dev (must match API_TOKEN on the server).
# In production, use the server-side API_TOKEN env var instead — it is
# injected by server.mjs through /api-proxy/ and never reaches the browser.
VITE_API_TOKEN=

# Optional: WatchLab URL for the "Library" nav link
VITE_WATCHLAB_URL=http://localhost:3000

# Optional: Comma-separated fallback production API URLs
# VITE_PROD_API_BASE_URLS=https://your-api.example.com

# ── Supabase Auth (optional — dashboard works without these) ──────────────
# VITE_SUPABASE_URL=https://kwdhkalwbwnjhywmkrnt.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key-here
# When set, the dashboard shows a login page and uses Supabase JWTs for API auth.
# Without these, the dashboard runs unauthenticated (local dev mode).

# ── Server-side only (server.mjs, NOT inlined by Vite) ───────────────────
# API_TOKEN=            # Bearer token for biograph API (production only)
# API_BASE_URL=         # biograph API origin for the proxy (production only)
# SUPABASE_URL=         # Set on biograph-api — enables ES256 JWT verification via JWKS
#                       # (SUPABASE_JWT_SECRET is no longer needed — public key fetched automatically)
